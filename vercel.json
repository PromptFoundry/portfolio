{
  "rewrites": [
    { "source": "/projects/:project/((?!.*\\.).*)", "destination": "/projects/:project/index.html" },
    { "source": "/((?!api/)(?!.*\\.).*)", "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/videos/(.*)",
      "headers": [
        { "key": "Accept-Ranges", "value": "bytes" },
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/projects/arcis/(.*\\.mp4)",
      "headers": [
        { "key": "Accept-Ranges", "value": "bytes" },
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    }
  ]
}
